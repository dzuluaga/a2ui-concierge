# === Agent / LLM ===
# LiteLLM model id (provider/model). Swap with one env var; no code changes.
# Examples:
#   anthropic/claude-haiku-4-5     anthropic/claude-sonnet-4-6
#   gemini/gemini-2.5-flash        gemini/gemini-2.5-flash-lite
#   deepseek/deepseek-chat         openai/gpt-4o-mini
MODEL=anthropic/claude-haiku-4-5

# Provide at least one key matching the MODEL above. Unused providers can
# stay unset.
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Optional: agent response budget. Bigger = fewer length-truncations,
# higher token cost.
# MAX_TOKENS=1500

# === x402 USDC payments ===
# Mock-settles by default; set to 1 to forward signed envelopes to the
# public x402 facilitator (returns real BaseScan-verifiable tx hashes).
X402_SETTLE_REAL=0
# Destination wallet for on-chain transfers. Required when SETTLE_REAL=1;
# anything you control. Defaults to the zero address, which the
# facilitator will (correctly) reject — set this before going on-chain.
X402_PAY_TO_ADDRESS=0x0000000000000000000000000000000000000000
# Demo cap on per-order USDC amount. When set, every settled cart is
# clamped to this dollar value so a single faucet drip covers many
# orders during recording. Unset for production-style pricing.
X402_DEMO_MAX_PRICE=2

# Optional overrides — defaults are tuned for Base Sepolia USDC v2:
# X402_NETWORK=base-sepolia
# X402_CHAIN_ID=84532
# X402_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
# X402_USDC_NAME=USDC
# X402_USDC_VERSION=2
# X402_FACILITATOR_BASE=https://www.x402.org/facilitator
# X402_RESOURCE_URL=https://lumen-concierge.demo/order
MCP_URL=http://localhost:3001/mcp
